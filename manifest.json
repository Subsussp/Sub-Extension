{
  "manifest_version": 3,
  "name": "Subtitles overlay",
  "version": "1.0.0",
  "description": "An extension to overlay your favourite TV shows and movies with any subtitles",
  "permissions": ["activeTab", "storage", "scripting", "webRequest", "tabs","system.display"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons":{
    "16":"icons/16i.png",
    "32":"icons/32.png",
    "48":"icons/48.png",
    "128": "icons/128.png"

  },

  "action": {
    "default_popup": "popup.html",
    "default_icon":{      
      "16": "icons/16i.png",
      "32": "icons/32.png",
      "48":"icons/48.png",
      "128": "icons/128.png"}
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "matches": ["*://*/*"],
      "resources": ["VideoPlayer/*"]
    }
  ]
}